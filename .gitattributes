# Normalize line endings automatically
* text=auto eol=lf

# Solidity
*.sol text eol=lf

# JavaScript / React
*.js text eol=lf
*.jsx text eol=lf

# JSON
*.json text eol=lf

# CSS
*.css text eol=lf

# HTML
*.html text eol=lf

# Markdown
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
